{
  "schemaVersion": 1,
  "id": "windsurf",
  "name": "Windsurf",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#111111",
  "platformSupport": {
    "windows": {
      "state": "experimental"
    }
  },
  "lines": [
    {
      "type": "progress",
      "label": "Daily quota",
      "scope": "overview",
      "primaryOrder": 1
    },
    {
      "type": "progress",
      "label": "Weekly quota",
      "scope": "overview"
    },
    {
      "type": "text",
      "label": "Extra usage balance",
      "scope": "detail"
    },
    {
      "type": "text",
      "label": "Source",
      "scope": "detail"
    },
    {
      "type": "text",
      "label": "Quota basis",
      "scope": "detail"
    }
  ],
  "capabilities": {
    "http": true,
    "httpDomains": [
      "server.self-serve.windsurf.com"
    ]
  }
}
