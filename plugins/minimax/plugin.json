{
  "schemaVersion": 1,
  "id": "minimax",
  "name": "MiniMax",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#F5433C",
  "platformSupport": {
    "windows": {
      "state": "experimental",
      "message": "Experimental on Windows. Save a MiniMax API key in Setup, or set MINIMAX_API_KEY / MINIMAX_CN_API_KEY before launching UsageBar."
    }
  },
  "lines": [
    {
      "type": "progress",
      "label": "Session",
      "scope": "overview",
      "primaryOrder": 1
    }
  ],
  "capabilities": {
    "http": true,
    "httpDomains": [
      "api.minimax.io",
      "www.minimax.io",
      "api.minimaxi.com"
    ]
  }
}
