{
  "schemaVersion": 1,
  "id": "kiro",
  "name": "Kiro",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "platformSupport": {
    "windows": {
      "state": "experimental",
      "message": "Windows experimental. UsageBar reads local Kiro desktop auth/cache state when present, or local Kiro CLI session metering as a fallback."
    }
  },
  "lines": [
    {
      "type": "progress",
      "label": "Credits",
      "scope": "overview",
      "primaryOrder": 1
    },
    {
      "type": "text",
      "label": "CLI Credits",
      "scope": "overview"
    },
    {
      "type": "progress",
      "label": "Bonus Credits",
      "scope": "detail"
    },
    {
      "type": "badge",
      "label": "Overages",
      "scope": "detail"
    }
  ],
  "capabilities": {
    "http": true,
    "httpDomains": [
      "prod.us-east-1.auth.desktop.kiro.dev",
      "*.amazonaws.com"
    ]
  }
}
