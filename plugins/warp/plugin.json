{
  "schemaVersion": 1,
  "id": "warp",
  "name": "Warp",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#111111",
  "platformSupport": {
    "windows": {
      "state": "experimental",
      "message": "Windows experimental. Use a stored Warp token or WARP_API_KEY / WARP_TOKEN to fetch request limits."
    }
  },
  "lines": [
    {
      "type": "progress",
      "label": "Requests",
      "scope": "overview",
      "primaryOrder": 1
    },
    {
      "type": "text",
      "label": "Requests",
      "scope": "overview"
    },
    {
      "type": "badge",
      "label": "Plan",
      "scope": "detail"
    },
    {
      "type": "text",
      "label": "Source",
      "scope": "detail"
    },
    {
      "type": "text",
      "label": "Auth source",
      "scope": "detail"
    },
    {
      "type": "text",
      "label": "Endpoint",
      "scope": "detail"
    }
  ],
  "capabilities": {
    "http": true,
    "httpDomains": [
      "app.warp.dev"
    ]
  }
}
