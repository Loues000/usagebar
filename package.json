{
  "name": "usagebar",
  "private": true,
  "version": "0.1.0-alpha.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run typecheck && bun run build:frontend",
    "build:frontend": "vite build",
    "build:release": "node ./scripts/build-release.mjs",
    "release:check": "node ./scripts/release-preflight.mjs",
    "ccusage:bump": "node ./scripts/bump-ccusage-version.mjs",
    "bundle:plugins": "node ./copy-bundled.cjs",
    "check": "bun run format:check && bun run lint && bun run typecheck",
    "format": "bun prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css,html}\" && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:check": "node ./scripts/check-format.mjs",
    "lint": "bun eslint src plugins scripts copy-bundled.cjs vite.config.ts eslint.config.js",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage.enabled",
    "tauri": "node ./scripts/tauri/wrapper.mjs",
    "typecheck": "tsc --noEmit",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
